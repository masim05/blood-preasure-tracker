        android:pathData="M82,8 L196,8 L196,140 Q196,142 194,142 L82,142 Q80,142 80,140 L80,10 Q80,8 82,8 Z"
        android:fillColor="#E2E8F0" />

    <!-- Systolic reading (partially visible) -->
    <path
        android:pathData="M88,22 L200,22 L200,39 L88,39 Z"
        android:fillColor="#FFFFFF" />

    <!-- Diastolic / pulse (mostly cropped) -->
    <path
        android:pathData="M88,46 L108,46 L108,57 L88,57 Z"
        android:fillColor="#FFFFFF" />
    <path
        android:pathData="M112,46 L200,46 L200,57 L112,57 Z"
        android:fillColor="#FFFFFF" />

</vector>
