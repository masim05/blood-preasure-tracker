        android:pathData="M80,0 L200,0 L200,145 Q200,155 190,155 L80,155 Q70,155 70,145 L70,10 Q70,0 80,0 Z"
        android:fillColor="#1E293B" />

    <!-- Monitor screen bezel (also partially clipped) -->
