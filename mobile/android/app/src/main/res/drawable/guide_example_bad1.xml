        android:pathData="M0,158 Q0,148 10,148 L155,148 Q165,148 165,158 L165,168 Q165,178 155,178 L10,178 Q0,178 0,168 Z"
        android:fillColor="#D6A77A" />

    <!-- Monitor body: partially outside the canvas (right and top edges clipped) -->
