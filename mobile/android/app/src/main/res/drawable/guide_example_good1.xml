<?xml version="1.0" encoding="utf-8"?>
<!-- Good example 1: full blood-pressure monitor display centred, arm visible -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="200dp"
    android:height="200dp"
    android:viewportWidth="200"
    android:viewportHeight="200">

    <!-- Background -->
    <path
        android:pathData="M0,0 L200,0 L200,200 L0,200 Z"
        android:fillColor="#E0F2FE" />

    <!-- Arm (horizontal rounded bar near the bottom) -->
    <path
        android:pathData="M30,155 Q30,145 40,145 L160,145 Q170,145 170,155 L170,165 Q170,175 160,175 L40,175 Q30,175 30,165 Z"
        android:fillColor="#D6A77A" />

    <!-- Monitor body -->
    <path
        android:pathData="M60,50 Q60,40 70,40 L130,40 Q140,40 140,50 L140,130 Q140,140 130,140 L70,140 Q60,140 60,130 Z"
        android:fillColor="#1E293B" />

    <!-- Monitor screen bezel -->
    <path
        android:pathData="M70,55 Q68,55 68,57 L68,125 Q68,127 70,127 L130,127 Q132,127 132,125 L132,57 Q132,55 130,55 Z"
        android:fillColor="#E2E8F0" />

    <!-- Systolic reading (large number block) -->
    <path
        android:pathData="M78,68 L122,68 L122,85 L78,85 Z"
        android:fillColor="#FFFFFF" />

    <!-- Diastolic / pulse reading (small number blocks) -->
    <path
        android:pathData="M78,92 L98,92 L98,103 L78,103 Z"
        android:fillColor="#FFFFFF" />
    <path
        android:pathData="M102,92 L122,92 L122,103 L102,103 Z"
        android:fillColor="#FFFFFF" />

    <!-- Label bar at bottom of screen -->
    <path
        android:pathData="M82,110 L118,110 L118,116 L82,116 Z"
        android:fillColor="#94A3B8" />

</vector>
