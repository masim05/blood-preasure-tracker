{
  "name": "blood-pressure-tracker",
  "version": "0.1.0",
  "private": true,
  "description": "CLI eval tool for blood pressure monitor image extraction",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "api": "npm run build --silent && node dist/api-main.js",
    "cli": "npm run build --silent && node dist/main.js",
    "deploy": "node scripts/deploy.mjs",
    "db:clean": "node scripts/db-clean.mjs",
    "db:connect": "node scripts/db-connect.mjs",
    "db:init": "node scripts/db-init.mjs",
    "db:migrate": "node scripts/db-migrate.mjs",
    "openapi:generate": "node scripts/generate-openapi-with-copilot.mjs",
    "openapi:serve": "node scripts/serve-openapi-docs.mjs",
    "test": "jest --runInBand --testPathIgnorePatterns=tests/integration --testPathIgnorePatterns=tests/bootstrap",
    "test:coverage": "jest --runInBand --coverage --testPathIgnorePatterns=tests/integration --testPathIgnorePatterns=tests/bootstrap",
    "test:integration": "jest --runInBand --testPathPatterns=tests/integration/.*\\.test\\.ts$",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "dependencies": {
    "@nestjs/common": "^11.1.23",
    "@nestjs/core": "^11.1.23",
    "@nestjs/platform-express": "^11.1.23",
    "exif-parser": "0.1.12",
    "openai": "^6.39.0",
    "pg": "^8.13.1",
    "postgres-migrations": "^5.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.23",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.4",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^8.33.1",
    "@typescript-eslint/parser": "^8.33.1",
    "eslint": "^9.27.0",
    "jest": "^30.0.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
